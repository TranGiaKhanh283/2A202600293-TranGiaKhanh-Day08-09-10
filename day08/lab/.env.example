# Day 08 Lab — RAG Pipeline
# Copy file này thành .env và điền API key

# === LLM Provider ===
# Chọn "openai" hoặc "gemini"
LLM_PROVIDER=openai

# OpenAI API (https://platform.openai.com/api-keys) — hoặc dùng GitHub Models bên dưới
# OPENAI_API_KEY=sk-...

# GitHub Models: PAT có scope "models" — https://github.com/settings/tokens
# Chỉ cần GITHUB_TOKEN: base mặc định là https://models.github.ai/inference
# (URL cũ *.inference.ai.azure.com đã deprecated, thường trả 404).
GITHUB_TOKEN=your_github_token

# Tuỳ chọn: OPENAI_BASE_URL=https://models.github.ai/inference

# Google Gemini (https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=...

# Model mặc định
LLM_MODEL=gpt-4o-mini
# GEMINI_MODEL=gemini-1.5-flash

# === Embedding ===
# Chọn "openai" hoặc "local" (sentence-transformers)
EMBEDDING_PROVIDER=local

# Model sentence-transformers nếu dùng local embedding
# LOCAL_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# Eval / CI: không gọi LLM (câu trả lời stub)
# SKIP_LLM=1

# Abstain theo điểm dense top-1 — CHỈ khi retrieval_mode=dense (0 = tắt)
# MIN_DENSE_SIM_FOR_ANSWER=0

# Khi điểm retrieval thấp, tăng số chunk gửi LLM (mặc định bật — hữu ích với embedding yếu)
# LOW_RETRIEVAL_SCORE_THRESHOLD=0.18
# EXPAND_WEAK_RETRIEVAL=1
# MAX_SELECT_WHEN_WEAK=6
