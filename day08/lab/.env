# Day 08 Lab — RAG Pipeline
# Copy file này thành .env và điền API key

# === LLM Provider ===
# Chọn "openai" hoặc "gemini"
LLM_PROVIDER=openai

# OpenAI API (https://platform.openai.com/api-keys) — hoặc dùng GitHub Models bên dưới
# OPENAI_API_KEY=sk-...

# GitHub Models (miễn phí qua inference): Personal Access Token có quyền models
# https://github.com/settings/tokens — khi chỉ dùng GITHUB_TOKEN, script tự dùng:
#   base_url=https://models.inference.ai.azure.com/v1
GITHUB_TOKEN=your_github_token

# Ghi đè base URL (bắt buộc nếu bạn đặt token GitHub vào OPENAI_API_KEY thay vì GITHUB_TOKEN)
# OPENAI_BASE_URL=https://models.inference.ai.azure.com/v1

# Google Gemini (https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=...

# Model mặc định
LLM_MODEL=gpt-4o-mini
# GEMINI_MODEL=gemini-1.5-flash

# === Embedding ===
# Chọn "openai" hoặc "local" (sentence-transformers)
EMBEDDING_PROVIDER=local

# Model sentence-transformers nếu dùng local embedding
# LOCAL_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# Eval / CI: không gọi LLM (câu trả lời stub)
# SKIP_LLM=1

# Abstain tùy điểm dense (0 = tắt; ví dụ 0.2)
# MIN_DENSE_SIM_FOR_ANSWER=0
